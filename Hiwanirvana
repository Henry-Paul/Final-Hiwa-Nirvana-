    <!-- INTERACTIVE JAVASCRIPT -->
    <script>
        // 1. Initialize Lucide Icons
        lucide.createIcons();
        document.getElementById('year').innerText = new Date().getFullYear();

        // 2. Tab Navigation Logic
        function switchTab(tabId) {
            // Hide all sections
            document.querySelectorAll('.view-section').forEach(sec => sec.classList.remove('active'));
            // Show target section
            document.getElementById(tabId).classList.add('active');
            
            // Scroll to top
            window.scrollTo(0, 0);

            // Update Desktop Nav Styling
            document.querySelectorAll('.nav-btn').forEach(btn => {
                if (btn.dataset.target === tabId) {
                    btn.className = "nav-btn text-sm uppercase tracking-wide font-medium transition-colors duration-200 text-emerald-800 border-b-2 border-emerald-800 pb-1";
                } else {
                    btn.className = "nav-btn text-sm uppercase tracking-wide font-medium transition-colors duration-200 text-slate-500 hover:text-emerald-700";
                }
            });

            // Update Mobile Nav Styling
            document.querySelectorAll('.mobile-nav-btn').forEach(btn => {
                if (btn.dataset.target === tabId) {
                    btn.className = "mobile-nav-btn block w-full text-left px-3 py-4 text-sm uppercase tracking-wider font-medium border-b border-slate-50 text-emerald-800 bg-emerald-50/50";
                } else {
                    btn.className = "mobile-nav-btn block w-full text-left px-3 py-4 text-sm uppercase tracking-wider font-medium border-b border-slate-50 text-slate-600";
                }
            });

            // Close mobile menu if open
            document.getElementById('mobile-menu').classList.add('hidden');
            let iconElement = document.querySelector('#mobile-menu-btn i');
            iconElement.setAttribute('data-lucide', 'menu');
            lucide.createIcons();
        }

        // 3. Mobile Menu Toggle
        document.getElementById('mobile-menu-btn').addEventListener('click', function() {
            const menu = document.getElementById('mobile-menu');
            const iconElement = this.querySelector('i');
            
            if (menu.classList.contains('hidden')) {
                menu.classList.remove('hidden');
                iconElement.setAttribute('data-lucide', 'x');
            } else {
                menu.classList.add('hidden');
                iconElement.setAttribute('data-lucide', 'menu');
            }
            lucide.createIcons();
        });

        // 4. Loan Calculator Logic
        const pInput = document.getElementById('calc-principal');
        const rInput = document.getElementById('calc-rate');
        const yInput = document.getElementById('calc-years');
        const pVal = document.getElementById('val-principal');
        const rVal = document.getElementById('val-rate');
        const yVal = document.getElementById('val-years');
        const emiDisplay = document.getElementById('calc-emi');

        const formatCurrency = (num) => {
            return new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(num);
        };

        function calculateEMI() {
            const p = parseFloat(pInput.value);
            const r = parseFloat(rInput.value) / 12 / 100;
            const n = parseFloat(yInput.value) * 12;

            pVal.innerText = formatCurrency(p);
            rVal.innerText = rInput.value + '% p.a.';
            yVal.innerText = yInput.value + ' Years';

            if (p > 0 && r > 0 && n > 0) {
                const emi = (p * r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
                emiDisplay.innerText = formatCurrency(Math.round(emi));
            } else {
                emiDisplay.innerText = '₹0';
            }
        }

        [pInput, rInput, yInput].forEach(input => input.addEventListener('input', calculateEMI));
        calculateEMI(); // Init calculation

        // 5. Generate and handle FAQs
        const faqs = [
            { q: "Why is investing in Pocharam the best choice?", a: "Pocharam is one of Hyderabad's fastest-growing IT and residential corridors. Home to major hubs like the Infosys SEZ and surrounded by top educational institutions, it offers high appreciation potential. The serene environment, combined with upcoming infrastructure projects and proximity to the ORR, makes it a perfect blend of peaceful living and smart investment." },
            { q: "What is the total open space available in the community?", a: "Hiwa Nirvana boasts an expansive 65% open space, thoughtfully designed with green courts, wide avenues, and landscaping to ensure a harmonious connection with nature." },
            { q: "Is the project approved by governing bodies?", a: "Yes, Hiwa Nirvana is a fully HMDA and TG RERA approved premium villa community, ensuring complete transparency and security for your investment." },
            { q: "What smart and sustainable features are included?", a: "We have integrated solar power back-up for common areas and street lights, provisions for EV car charging points in parking areas, and robust security including solar fencing." }
        ];

        const faqContainer = document.getElementById('faq-container');
        faqs.forEach((faq, index) => {
            const faqHTML = `
                <div class="faq-item border border-slate-200 rounded-lg bg-white overflow-hidden transition-all duration-300 cursor-pointer" onclick="toggleFAQ(${index})">
                    <div class="w-full px-6 py-5 flex justify-between items-center focus:outline-none">
                        <span class="font-medium text-slate-800 pr-4">${faq.q}</span>
                        <i data-lucide="chevron-down" id="faq-icon-${index}" class="w-5 h-5 text-slate-400 shrink-0 transition-transform duration-300"></i>
                    </div>
                    <div id="faq-answer-${index}" class="px-6 max-h-0 opacity-0 overflow-hidden transition-all duration-300 ease-in-out">
                        <p class="text-slate-600 font-light leading-relaxed border-t border-slate-100 pt-4 pb-5">${faq.a}</p>
                    </div>
                </div>
            `;
            faqContainer.innerHTML += faqHTML;
        });
        lucide.createIcons();

        function toggleFAQ(index) {
            const answer = document.getElementById(`faq-answer-${index}`);
            const icon = document.getElementById(`faq-icon-${index}`);
            const parent = answer.parentElement;
            
            const isOpen = parent.classList.contains('ring-2');

            // Close all
            document.querySelectorAll('.faq-item').forEach((item, i) => {
                item.classList.remove('ring-2', 'ring-emerald-500/20', 'shadow-md');
                document.getElementById(`faq-answer-${i}`).style.maxHeight = '0px';
                document.getElementById(`faq-answer-${i}`).style.opacity = '0';
                document.getElementById(`faq-icon-${i}`).style.transform = 'rotate(0deg)';
                document.getElementById(`faq-icon-${i}`).classList.remove('text-emerald-600');
            });

            // Open clicked if it wasn't already open
            if (!isOpen) {
                parent.classList.add('ring-2', 'ring-emerald-500/20', 'shadow-md');
                answer.style.maxHeight = answer.scrollHeight + 'px';
                answer.style.opacity = '1';
                icon.style.transform = 'rotate(180deg)';
                icon.classList.add('text-emerald-600');
            }
        }
        
        // Open the first FAQ by default
        setTimeout(() => toggleFAQ(0), 100);
    </script>
</body>
</html>

